// Instruction
// - For "name", make it unique among existing containers
// - For "service", make it match the service name in docker-compose.yml
{
    "name": "{{devcontainer_name}}",
    "dockerComposeFile": [
        "docker-compose.yml"
    ],
    // the service in docker-compose.yml
    "service": "{{service}}",
    "shutdownAction": "stopCompose",
    // KEYNOTE: make this consistent with the volume mount target in docker-compose.yml
    "workspaceFolder": "/root/workspace",
    "customizations": {
        "vscode": {
            "settings": {
                "files.eol": "\n",
                "dev.containers.cacheVolume": true,
                "gitProjectManager.baseProjectsFolders": [
                    "~/workspace"
                ]
            }
        }
    }
    // "postCreateCommand": "",
}
